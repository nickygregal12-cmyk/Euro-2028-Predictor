# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit Supabase keys or the dev password.

# --- Supabase (dev project) — Project Settings → API ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# --- Dev auto-login shim (docs/auth-plan.md §1) — DEV BUILDS ONLY ---
# While auth screens are deferred, `npm run dev` can silently sign in as the
# seeded dev user so the whole auth pipeline (sessions, auth.uid(), RLS) is live.
#
# Set VITE_DEV_AUTOLOGIN=true to enable it, and seed the dev user first
# (see supabase/dev-user.sql). VITE_DEV_USER_EMAIL / _PASSWORD must match the
# credentials you gave that user.
#
# FAIL-CLOSED: a production build (`npm run build`) with VITE_DEV_AUTOLOGIN=true
# refuses to build, and the runtime shim refuses to start. Leave it false/unset
# for anything that ships.
VITE_DEV_AUTOLOGIN=false
VITE_DEV_USER_EMAIL=dev@euro28.local
VITE_DEV_USER_PASSWORD=set-this-to-match-the-dashboard-user

# --- Cloudflare Turnstile (bot protection on auth) — OFF by default ---
# PUBLIC Turnstile site key. When set, the log-in / sign-up forms render the
# Turnstile widget and send a captchaToken to Supabase Auth. LEAVE UNSET to keep
# auth exactly as-is. You must ALSO enable Turnstile in the Supabase dashboard
# (Authentication → CAPTCHA) with the matching SECRET — the two move together
# (a token while CAPTCHA is disabled, or CAPTCHA enabled without a token, both
# error). The secret never lives in this repo; Supabase holds it and runs
# siteverify. In Netlify, add VITE_TURNSTILE_SITE_KEY to the site's env vars too.
VITE_TURNSTILE_SITE_KEY=
# Dev auto-login is headless (no widget). If you enable CAPTCHA on the DEV
# Supabase project, configure it with Cloudflare's always-passes TEST secret
# (1x0000000000000000000000000000000AA) and set any dummy value here so startup
# sign-in still passes. For a real-checkbox dev experience, use Cloudflare's TEST
# site key (1x00000000000000000000AA) as VITE_TURNSTILE_SITE_KEY. Leave blank off.
VITE_TURNSTILE_DEV_TOKEN=
