# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit Supabase keys or the dev password.

# --- Supabase (dev project) — Project Settings → API ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# --- Dev auto-login shim (docs/auth-plan.md §1) — DEV BUILDS ONLY ---
# While auth screens are deferred, `npm run dev` can silently sign in as the
# seeded dev user so the whole auth pipeline (sessions, auth.uid(), RLS) is live.
#
# Set VITE_DEV_AUTOLOGIN=true to enable it, and seed the dev user first
# (see supabase/dev-user.sql). VITE_DEV_USER_EMAIL / _PASSWORD must match the
# credentials you gave that user.
#
# FAIL-CLOSED: a production build (`npm run build`) with VITE_DEV_AUTOLOGIN=true
# refuses to build, and the runtime shim refuses to start. Leave it false/unset
# for anything that ships.
VITE_DEV_AUTOLOGIN=false
VITE_DEV_USER_EMAIL=dev@euro28.local
VITE_DEV_USER_PASSWORD=set-this-to-match-the-dashboard-user
